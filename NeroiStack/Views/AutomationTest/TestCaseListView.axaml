<UserControl
	x:Class="NeroiStack.Views.AutomationTest.TestCaseListView"
	xmlns="https://github.com/avaloniaui"
	xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
	xmlns:fluenticons="using:FluentIcons.Avalonia"
	xmlns:vm="clr-namespace:NeroiStack.ViewModels.AutomationTest"
	x:DataType="vm:TestCaseListViewModel">
	<UserControl.Styles>
		<Style Selector="ListBoxItem">
			<Setter Property="Padding" Value="0" />
			<Setter Property="Margin" Value="8,4" />
			<Setter Property="Background" Value="Transparent" />
			<Setter Property="Template">
				<ControlTemplate>
					<Border
						Name="SelectionIndicator"
						Padding="12,8"
						Background="{TemplateBinding Background}"
						CornerRadius="8">
						<ContentPresenter Content="{TemplateBinding Content}" />
					</Border>
				</ControlTemplate>
			</Setter>
		</Style>
		<Style Selector="ListBoxItem:pointerover /template/ Border#SelectionIndicator">
			<Setter Property="Background" Value="{DynamicResource SystemControlBackgroundChromeMediumBrush}" />
		</Style>
		<Style Selector="ListBoxItem:selected /template/ Border#SelectionIndicator">
			<Setter Property="Background" Value="{DynamicResource SystemControlHighlightAccentBrushLow}" />
			<Setter Property="BorderBrush" Value="{DynamicResource SystemControlHighlightAccentBrush}" />
			<Setter Property="BorderThickness" Value="1" />
		</Style>
	</UserControl.Styles>

	<Grid RowDefinitions="Auto, *">
		<Border
			Grid.Row="0"
			Padding="20,15"
			BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
			BorderThickness="0,0,0,1">
			<Grid ColumnDefinitions="*, Auto">
				<TextBlock
					VerticalAlignment="Center"
					FontSize="18"
					FontWeight="SemiBold"
					Text="Test Cases" />
				<Button
					Grid.Column="1"
					Width="32"
					Height="32"
					Padding="0"
					Classes="accent"
					Command="{Binding CreateNewTestCaseCommand}"
					CornerRadius="16">
					<fluenticons:SymbolIcon FontSize="18" Symbol="Add" />
				</Button>
			</Grid>
		</Border>

		<ListBox
			Grid.Row="1"
			Background="Transparent"
			BorderThickness="0"
			ItemsSource="{Binding TestCases}"
			SelectedItem="{Binding SelectedTestCase}">
			<ListBox.ItemTemplate>
				<DataTemplate>
					<Grid ColumnDefinitions="*, Auto">
						<StackPanel Spacing="2">
							<TextBlock
								FontSize="14"
								FontWeight="Medium"
								Text="{Binding Name}" />
							<TextBlock
								FontSize="11"
								MaxLines="1"
								Opacity="0.5"
								Text="{Binding Url}"
								TextTrimming="CharacterEllipsis" />
						</StackPanel>
						<Button
							Grid.Column="1"
							Margin="4,0,0,0"
							Padding="4"
							Background="Transparent"
							Command="{Binding $parent[UserControl].((vm:TestCaseListViewModel)DataContext).DeleteTestCaseCommand}"
							CommandParameter="{Binding}">
							<fluenticons:SymbolIcon
								FontSize="14"
								Foreground="{DynamicResource SystemControlErrorTextForegroundBrush}"
								Opacity="0.4"
								Symbol="Delete" />
						</Button>
					</Grid>
				</DataTemplate>
			</ListBox.ItemTemplate>
		</ListBox>
	</Grid>

</UserControl>
